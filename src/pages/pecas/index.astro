---
import Base from '../../layouts/Base.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';

const cases = (await getCollection('cases')).sort((a, b) => b.data.ano - a.data.ano);
---
<Base title="Peças">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-5xl">Peças</h1>
    <p class="mt-4 text-carvao/70 max-w-xl">Cada peça é única. Abaixo, uma seleção.</p>
    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cases.map((c) => <CaseCard entry={c} />)}
    </div>
  </section>
</Base>
