---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('caderno');
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.titulo} description={entry.data.resumo}>
  <article class="max-w-2xl mx-auto px-6 py-20">
    <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-carvao/60">{entry.data.data.toISOString().slice(0, 10)}</div>
    <h1 class="mt-4 text-5xl">{entry.data.titulo}</h1>
    <p class="mt-6 text-lg text-carvao/80">{entry.data.resumo}</p>
    <div class="prose prose-neutral mt-12 max-w-none"><Content /></div>
  </article>
</Base>
