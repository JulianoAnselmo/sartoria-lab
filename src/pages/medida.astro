---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import BriefingForm from '../components/BriefingForm.astro';
---
<Base title="Agende uma medida">
  <Hero label="Medida" title="Agende" titleItalic="uma medida" subtitle="Me conta do projeto. Em até 2 dias úteis, retorno com as perguntas certas — e, se houver encaixe, uma proposta sob medida." />
  <section class="max-w-3xl mx-auto px-6 pb-24">
    <BriefingForm />
  </section>
</Base>
