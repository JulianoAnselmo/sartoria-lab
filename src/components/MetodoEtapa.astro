---
interface Props { numero: string; nome: string; }
const { numero, nome } = Astro.props;
---
<div class="grid grid-cols-[auto_auto_1fr] gap-6 items-baseline py-5 border-t border-giz">
  <div class="font-mono text-[11px] text-linha tracking-[0.2em]">{numero}</div>
  <div class="font-display text-2xl">{nome}</div>
  <div class="text-sm text-carvao/80 leading-relaxed"><slot /></div>
</div>
