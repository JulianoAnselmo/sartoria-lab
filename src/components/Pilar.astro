---
interface Props {
  numero: string;
  titulo: string;
}
const { numero, titulo } = Astro.props;
---
<article class="border-t border-giz pt-6">
  <div class="font-mono text-[11px] text-linha tracking-[0.2em]">{numero}</div>
  <h3 class="mt-2 text-2xl">{titulo}</h3>
  <div class="mt-3 text-sm text-carvao/80 leading-relaxed"><slot /></div>
</article>
