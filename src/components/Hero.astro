---
interface Props {
  label?: string;
  title: string;
  titleItalic?: string;
  subtitle?: string;
  cta?: { href: string; label: string };
}
const { label, title, titleItalic, subtitle, cta } = Astro.props;
---
<section class="max-w-3xl mx-auto px-6 pt-24 pb-20 text-center">
  {label && <p class="text-[10px] tracking-[0.3em] uppercase text-carvao/60">{label}</p>}
  <h1 class="mt-6 text-5xl md:text-7xl leading-[0.95]">
    {title}
    {titleItalic && <><br/><em class="font-medium">{titleItalic}</em>.</>}
  </h1>
  <div class="w-10 h-px bg-linha mx-auto my-8"></div>
  {subtitle && <p class="max-w-md mx-auto text-carvao/80">{subtitle}</p>}
  {cta && (
    <a href={cta.href} class="inline-block mt-8 px-6 py-3 bg-carvao text-papel text-[11px] tracking-[0.2em] uppercase no-underline">{cta.label}</a>
  )}
</section>
