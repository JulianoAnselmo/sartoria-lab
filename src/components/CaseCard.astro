---
import type { CollectionEntry } from 'astro:content';
import MonoMeta from './MonoMeta.astro';

interface Props { entry: CollectionEntry<'cases'>; }
const { entry } = Astro.props;
const { titulo, cliente, categoria, ano, stack } = entry.data;
---
<a href={`/pecas/${entry.id}`} class="block border border-giz p-6 no-underline hover:border-carvao transition-colors">
  <MonoMeta items={[categoria, String(ano)]} />
  <h3 class="mt-3 text-xl">{titulo}</h3>
  <p class="mt-1 text-sm text-carvao/70">{cliente}</p>
  <p class="mt-3 text-xs text-carvao/60">{stack.join(' · ')}</p>
</a>
