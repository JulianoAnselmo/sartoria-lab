---
const year = new Date().getFullYear();
---
<footer class="border-t border-giz mt-24">
  <div class="max-w-5xl mx-auto px-6 py-10 grid md:grid-cols-3 gap-8 text-sm">
    <div>
      <div class="font-display text-lg">Sartoria Lab</div>
      <p class="mt-2 text-carvao/70">Tecnologia sob medida.</p>
    </div>
    <div>
      <div class="text-[10px] tracking-[0.2em] uppercase text-carvao/60 mb-2">Contato</div>
      <a href="mailto:contato@sartorialab.com.br" class="no-underline">contato@sartorialab.com.br</a>
    </div>
    <div class="text-[11px] font-mono text-carvao/60 md:text-right">
      © {year} · Sartoria Lab
    </div>
  </div>
</footer>
